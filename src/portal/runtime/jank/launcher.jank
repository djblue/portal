(ns portal.runtime.jank.launcher
  (:include "GLFW/glfw3.h"
            "cairo/cairo.h"))

(cpp/raw "
namespace portal::runtime::jank::launcher {
void render_cario_surface(unsigned char* data)
{
// Generate and bind texture
GLuint texture;
glGenTextures(1, &texture);
glBindTexture(GL_TEXTURE_2D, texture);
glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MIN_FILTER, GL_LINEAR);
glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MAG_FILTER, GL_LINEAR);

// Upload Cairo data (ARGB32 → BGRA)
glTexImage2D(GL_TEXTURE_2D, 0, GL_RGBA, 800, 600, 0, GL_BGRA, GL_UNSIGNED_BYTE, data);

// Draw fullscreen quad
glEnable(GL_TEXTURE_2D);
glBegin(GL_QUADS);
  glTexCoord2f(0, 0); glVertex2f(-1, 1);
  glTexCoord2f(1, 0); glVertex2f(1, 1);
  glTexCoord2f(1, 1); glVertex2f(1, -1);
  glTexCoord2f(0, 1); glVertex2f(-1, -1);
glEnd();
}
}
")

